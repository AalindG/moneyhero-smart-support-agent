# Server Configuration
PORT=3001

# Ollama Configuration
# Local development - use localhost
OLLAMA_BASE_URL=http://localhost:11434
# Docker - use service name (uncomment for Docker deployment)
# OLLAMA_BASE_URL=http://ollama:11434

# LLM Models (use specific versions to prevent drift)
# Main RAG model - use 3b or larger for production (7b recommended)
OLLAMA_MODEL=llama3.2:3b
# Intent classifier - 1b is sufficient for 3-way classification
OLLAMA_CLASSIFIER_MODEL=llama3.2:1b
# Embedding model - MUST match during ingestion and retrieval
OLLAMA_EMBED_MODEL=nomic-embed-text:v1.5

# Database
DB_PATH=./data/moneyhero.db

# Production Recommendations:
# - Use qwen2.5:7b for OLLAMA_MODEL (better instruction following)
# - Always pin embedding model versions with :vX.X
# - Run: ollama pull <model> for each model before starting
# - Re-run ingestion after changing OLLAMA_EMBED_MODEL
