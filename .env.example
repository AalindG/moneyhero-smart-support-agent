# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# Claude (Anthropic) — primary LLM
# Set USE_CLAUDE=true + add your API key to use Claude as the primary model.
# Ollama is always the fallback regardless of this setting.
# ─────────────────────────────────────────────────────────────────────────────
USE_CLAUDE=false
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=500

# ─────────────────────────────────────────────────────────────────────────────
# Ollama — fallback LLM + embeddings (always local)
# For Docker deployment use: OLLAMA_BASE_URL=http://ollama:11434
# ─────────────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_MAX_TOKENS=900
OLLAMA_TEMPERATURE=0

# ─────────────────────────────────────────────────────────────────────────────
# RAG retrieval
# RETRIEVAL_SCORE_THRESHOLD: HNSWLib cosine-distance cut-off (0.0–2.0).
#   Lower = stricter. 0.75 is a good balance for financial FAQ queries.
# RETRIEVAL_K: number of candidate docs fetched before threshold filtering.
# ─────────────────────────────────────────────────────────────────────────────
RETRIEVAL_SCORE_THRESHOLD=0.75
RETRIEVAL_K=30

# ─────────────────────────────────────────────────────────────────────────────
# Context window & session
# MAX_CONTEXT_TOKENS: soft limit on total prompt tokens (system + history).
# LLM_TIMEOUT_MS:     milliseconds before the LLM call is aborted.
# SESSION_TTL_MS:     milliseconds of inactivity before a session is evicted.
# ─────────────────────────────────────────────────────────────────────────────
MAX_CONTEXT_TOKENS=6000
LLM_TIMEOUT_MS=90000
SESSION_TTL_MS=3600000

# ─────────────────────────────────────────────────────────────────────────────
# Document ingestion (npm run ingest)
# Re-run ingestion after changing these — affects vectorstore chunk quality.
# ─────────────────────────────────────────────────────────────────────────────
CHUNK_SIZE=1500
CHUNK_OVERLAP=250

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
DB_PATH=./data/moneyhero.db

# ─────────────────────────────────────────────────────────────────────────────
# Rate limiting
# ─────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_GLOBAL_WINDOW_MS=900000
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_CHAT_WINDOW_MS=60000
RATE_LIMIT_CHAT_MAX=20

# ─────────────────────────────────────────────────────────────────────────────
# Escalation & SSE
# ─────────────────────────────────────────────────────────────────────────────
ESCALATION_COOLDOWN_MINUTES=10
SSE_KEEPALIVE_INTERVAL_MS=2000

# ─────────────────────────────────────────────────────────────────────────────
# CORS (comma-separated origins, or * for development)
# ─────────────────────────────────────────────────────────────────────────────
CORS_ORIGIN=*
