# Server Configuration
PORT=3001

# LLM Configuration
# Set USE_CLAUDE=true to use Claude Sonnet as primary LLM (with Ollama as fallback)
# Set USE_CLAUDE=false to use only Ollama (local development)
USE_CLAUDE=false

# Anthropic API (required if USE_CLAUDE=true)
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama Configuration (local LLM server)
# Local development - use localhost
OLLAMA_BASE_URL=http://localhost:11434
# Docker - use service name (uncomment for Docker deployment)
# OLLAMA_BASE_URL=http://ollama:11434

# LLM Models
# Main RAG model - upgraded to 3b for production quality
OLLAMA_MODEL=llama3.2:3b
# Embedding model - MUST match during ingestion and retrieval
OLLAMA_EMBED_MODEL=nomic-embed-text

# Database
DB_PATH=./data/moneyhero.db

# Production Recommendations:
# - Use Claude 3.5 Sonnet for production (USE_CLAUDE=true)
# - Ollama 3b is good for development
# - Always test with both Claude and Ollama fallback
# - Re-run ingestion after changing OLLAMA_EMBED_MODEL
