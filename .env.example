# Server Configuration
PORT=3001

# LLM Provider Selection
# Options: "claude" or "ollama"
LLM_PROVIDER=claude

# Claude API Configuration (when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=YOUR_API_KEY_HERE
# Claude model for all tasks (classification + RAG)
# Options: claude-3-haiku-20240307 (fast/cheap), claude-3-5-sonnet-20241022 (better quality)
CLAUDE_MODEL=claude-3-haiku-20240307
# Enable prompt caching to reduce costs by 90% (recommended)
CLAUDE_ENABLE_CACHING=true

# Ollama Configuration (for embeddings or when LLM_PROVIDER=ollama)
# Local development - use localhost
OLLAMA_BASE_URL=http://localhost:11434
# Docker - use service name (uncomment for Docker deployment)
# OLLAMA_BASE_URL=http://ollama:11434

# Ollama Models (fallback when LLM_PROVIDER=ollama)
OLLAMA_MODEL=llama3.2:3b
OLLAMA_CLASSIFIER_MODEL=llama3.2:1b

# Embedding model - MUST match during ingestion and retrieval
# Always use Ollama for embeddings (free, fast, and reliable)
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# Database
DB_PATH=./data/moneyhero.db

# Production Recommendations:
# - Use LLM_PROVIDER=claude for 5-8x faster responses
# - Keep CLAUDE_ENABLE_CACHING=true for 90% cost savings
# - Ollama still required for embeddings (nomic-embed-text)
# - Claude Haiku: ~$15-20/month for 1000 conversations/day
# - Always pin embedding model versions with :vX.X
